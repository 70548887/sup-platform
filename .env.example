# ===== 应用配置 =====
APP_NAME=sup-platform
APP_PORT=8080
APP_MODE=release

# ===== 数据库配置 =====
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
# 生产环境必须修改
DB_PASSWORD=CHANGE_IN_PRODUCTION
DB_NAME=sup_platform

# ===== Redis配置 =====
REDIS_ADDR=redis:6379
# 生产环境如有密码请配置
REDIS_PASSWORD=CHANGE_IN_PRODUCTION
REDIS_DB=0
REDIS_ENABLED=true
REDIS_PREFIX=sup

# ===== JWT配置 =====
# 使用 openssl rand -hex 32 生成
JWT_SECRET=CHANGE_IN_PRODUCTION
JWT_EXPIRE=72

# ===== 加密配置 =====
# 使用 openssl rand -hex 32 生成
CARD_ENCRYPT_KEY=CHANGE_IN_PRODUCTION

# ===== 多租户配置 =====
MULTI_TENANT_ENABLED=false
DEFAULT_TENANT_ID=1

# ===== 私有化部署初始化 =====
INIT_TENANT_NAME=我的公司
ADMIN_USERNAME=admin
# 生产环境必须修改为强密码
ADMIN_PASSWORD=CHANGE_IN_PRODUCTION

# ===== 亿乐对接（可选）=====
YILE_APP_ID=
# 生产环境如启用亿乐对接则必须配置
YILE_APP_SECRET=CHANGE_IN_PRODUCTION
YILE_BASE_URL=
