# ===== 应用配置 =====
APP_NAME=sup-platform
APP_PORT=8080
APP_MODE=release

# ===== 数据库配置 =====
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root123
